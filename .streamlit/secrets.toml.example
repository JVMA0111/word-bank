# Copie este arquivo para secrets.toml e preencha os valores reais.
# NUNCA commite secrets.toml — ele já está no .gitignore.

# String de conexão do Supabase (use o Session Pooler para compatibilidade IPv4)
# Encontre em: Supabase Dashboard → Connect → Session pooler
DATABASE_URL = "postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Os usuários agora são criados pela própria tela de cadastro do app
# e ficam armazenados na tabela `users` do banco — não precisa configurar aqui.
