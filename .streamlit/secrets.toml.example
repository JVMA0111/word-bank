# Copie este arquivo para secrets.toml e preencha os valores reais.
# NUNCA commite secrets.toml — ele já está no .gitignore.

# String de conexão do Supabase
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL = "postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Usuários da aplicação
# Para gerar o hash de uma senha, rode no terminal:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'sua_senha', bcrypt.gensalt()).decode())"

[users.joao]
name = "João Victor"
password_hash = "$2b$12$HASH_AQUI"

[users.maria]
name = "Maria Silva"
password_hash = "$2b$12$HASH_AQUI"
